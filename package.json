{
  "name": "etude-lexical-markdown",
  "private": true,
  "version": "0.6.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:vanilla": "vite examples/vanilla --no-clear-screen",
    "dev:tailwind": "vite examples/tailwind --no-clear-screen",
    "build:vanilla": "tsc -b && vite build examples/vanilla",
    "build:tailwind": "tsc -b && vite build examples/tailwind",
    "build:docs": "tsc -b && vite build examples/vanilla --base=/etude-lexical-markdown/ --outDir=../../docs --emptyOutDir",
    "preview:vanilla": "vite preview examples/vanilla",
    "preview:tailwind": "vite preview examples/tailwind",
    "check": "biome check",
    "fix": "biome check --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser"
  },
  "dependencies": {
    "@lexical/code-core": "^0.45.0",
    "@lexical/headless": "^0.45.0",
    "@lexical/history": "^0.45.0",
    "@lexical/html": "^0.45.0",
    "@lexical/list": "^0.45.0",
    "@lexical/markdown": "^0.45.0",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "lexical": "^0.45.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-react": "^2.2.0"
  }
}
